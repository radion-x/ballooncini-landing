# =====================================================
# Ballooncini Landing Page - Environment Variables
# =====================================================
# Copy this file to .env and fill in your actual values

# Server Configuration
PORT=3000
NODE_ENV=production

# Site Information
SITE_URL=https://ballooncini.com.au
SITE_NAME=Ballooncini

# Email Configuration (Mailgun)
# Sign up at https://www.mailgun.com/
MAILGUN_API_KEY=your_mailgun_api_key_here
MAILGUN_DOMAIN=mg.yourdomain.com
MAILGUN_REGION=us
RECIPIENT_EMAIL=info@ballooncini.com.au

# AI Chat Configuration (OpenRouter - Optional)
# Sign up at https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=openai/gpt-3.5-turbo
OPENROUTER_MAX_TOKENS=1000
OPENROUTER_TEMPERATURE=0.7
OPENROUTER_USE_STREAMING=false

# AI System Prompt
OPENROUTER_SYSTEM_PROMPT=You are a friendly and helpful balloon decoration assistant for Ballooncini in Haberfield, Sydney. Answer questions about balloon decorations, event styling, pricing, and bookings. Be warm, creative, and knowledgeable. Encourage getting a free quote. Phone: (02) 9716 7600. Address: 169 Ramsay St, Haberfield NSW 2045.

# Chat Suggested Questions (comma-separated)
CHAT_SUGGESTED_QUESTIONS=What balloon decorations do you offer?,How much do balloon arches cost?,Do you deliver across Sydney?,Can I get a free quote?,How far in advance should I book?
